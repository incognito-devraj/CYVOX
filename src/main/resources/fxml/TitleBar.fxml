<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.SVGPath?>

<HBox id="titleBarHandle" alignment="CENTER_LEFT" minHeight="58.0" prefHeight="58.0" spacing="14.0" styleClass="title-bar" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets left="48.0" right="30.0" />
    </padding>
    <Label styleClass="logo-text" text="CY" />
    <SVGPath content="M8 5v14l11-7z" scaleX="1.45" scaleY="1.45" styleClass="logo-mark" />
    <Label styleClass="logo-text" text="OX" />
    <Region HBox.hgrow="ALWAYS" />
    <Button id="settingsButton" mnemonicParsing="false" styleClass="title-icon-button" text="SET" />
    <Button id="minimizeButton" mnemonicParsing="false" styleClass="title-icon-button" text="_" />
    <Button id="maximizeButton" mnemonicParsing="false" styleClass="title-icon-button" text="[]" />
    <Button id="closeButton" mnemonicParsing="false" styleClass="title-icon-button close-button" text="X" />
</HBox>
