<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox id="progressView" managed="false" maxWidth="840.0" spacing="18.0" styleClass="progress-view" visible="false" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <HBox alignment="CENTER_LEFT" spacing="18.0">
        <StackPane id="progressIconWrap" styleClass="progress-icon-wrap">
            <SVGPath id="progressIcon" content="M8 5v14l11-7z" styleClass="progress-icon" />
        </StackPane>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label id="progressTitle" styleClass="progress-title" text="Compressing videos" />
            <Label id="currentFileValue" styleClass="progress-subtitle" text="Preparing queue" />
        </VBox>
        <Label id="progressPercentageValue" styleClass="progress-percent" text="0%" />
    </HBox>
    <ProgressBar id="compressionProgressBar" maxWidth="1.7976931348623157E308" progress="0.0" />
    <HBox alignment="CENTER_LEFT" spacing="18.0">
        <Label styleClass="progress-meta-label" text="Remaining" />
        <Label id="remainingTimeValue" styleClass="progress-meta-value" text="Estimating" />
        <Region HBox.hgrow="ALWAYS" />
        <Button id="pauseButton" mnemonicParsing="false" styleClass="secondary-action compact-action" text="Pause" />
        <Button id="cancelButton" mnemonicParsing="false" styleClass="danger-action compact-action" text="Cancel" />
        <Button id="openFolderButton" managed="false" mnemonicParsing="false" styleClass="secondary-action compact-action" text="Open Folder" visible="false" />
        <Button id="compressAnotherButton" managed="false" mnemonicParsing="false" styleClass="primary-action compact-action" text="Compress Another Folder" visible="false" />
    </HBox>
</VBox>
